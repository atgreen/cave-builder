ARG FEDORA_VERSION=43
FROM fedora:${FEDORA_VERSION}

# Add ocicl RPM repo
RUN dnf config-manager addrepo --from-repofile=https://ocicl.github.io/ocicl/rpm-repo/ocicl.repo

RUN dnf install -y \
        git \
        gcc \
        gcc-c++ \
        make \
        sbcl \
        ocicl \
        golang \
        autoconf \
        automake \
        libtool \
        python3 \
        python3-pip \
        zlib-devel \
    && dnf clean all

LABEL org.opencontainers.image.source="https://github.com/atgreen/cave-builder"
LABEL org.opencontainers.image.description="Fedora-based builder image"
