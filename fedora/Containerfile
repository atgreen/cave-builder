ARG FEDORA_VERSION=43
FROM fedora:${FEDORA_VERSION}

RUN dnf install -y \
        git \
        gcc \
        gcc-c++ \
        make \
        sbcl \
        golang \
        autoconf \
        automake \
        libtool \
        python3 \
        python3-pip \
        zlib-devel \
    && dnf clean all

# Install ocicl
RUN curl -L https://github.com/ocicl/ocicl/releases/latest/download/ocicl-linux-x86_64 \
        -o /usr/local/bin/ocicl \
    && chmod +x /usr/local/bin/ocicl \
    && ocicl version

LABEL org.opencontainers.image.source="https://github.com/atgreen/cave-builder"
LABEL org.opencontainers.image.description="Fedora-based builder image for Cave"
