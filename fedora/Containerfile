ARG FEDORA_VERSION=43
FROM fedora:${FEDORA_VERSION}

# Add ocicl RPM repo
RUN printf '[ocicl]\nname=ocicl\nbaseurl=https://ocicl.github.io/ocicl/rpm-repo\nenabled=1\ngpgcheck=1\nrepo_gpgcheck=1\ngpgkey=https://ocicl.github.io/ocicl/rpm-repo/RPM-GPG-KEY-ocicl\n' \
        > /etc/yum.repos.d/ocicl.repo

RUN dnf install -y \
        git \
        gcc \
        gcc-c++ \
        make \
        sbcl \
        ocicl \
        golang \
        autoconf \
        automake \
        libtool \
        python3 \
        python3-pip \
        zlib-devel \
    && dnf clean all

LABEL org.opencontainers.image.source="https://github.com/atgreen/cave-builder"
LABEL org.opencontainers.image.description="Fedora-based builder image"
